# Database (PostgreSQL with pgvector)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=open_brain
DB_USER=open_brain
DB_PASSWORD=generate-a-secure-password

# Embedding service (OpenAI-compatible /v1/embeddings endpoint)
EMBEDDING_BASE_URL=http://your-embedding-host:8791/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=embeddinggemma-300m-8bit
# Must match the DB schema (halfvec(768) columns) -- changing this requires a column migration + re-embed
EMBEDDING_DIMENSIONS=768
EMBEDDING_WATCHDOG_FAILURE_THRESHOLD=2
EMBEDDING_WATCHDOG_COOLDOWN_MS=300000
# Optional: executable script to run after repeated embedding provider failures
EMBEDDING_WATCHDOG_RESTART_SCRIPT=
# Optional: consumed by scripts/restart-mlx-embedding-server.sh when used as the watchdog restart script.
MLX_EMBED_DAEMON=
MLX_EMBED_RUNTIME_DIR=
MLX_EMBED_PORT=8791
MLX_EMBED_HEALTH_URL=http://127.0.0.1:8791/health
MLX_EMBED_CURL=
MLX_EMBED_HEALTH_RETRIES=20
MLX_EMBED_HEALTH_SLEEP_SECONDS=1
MLX_EMBED_RESTART_SETTLE_SECONDS=2
MLX_EMBED_RESTART_LOCK_STALE_AFTER_SECONDS=300

# Server
PORT=3100
DB_POOL_MAX=10
OPEN_BRAIN_RUN_MIGRATIONS=1

# CORS allowed origins (comma-separated, empty for none)
ALLOWED_ORIGINS=

# Auth tokens -- one per consumer role
# Generate with: openssl rand -hex 32
AUTH_TOKEN_ADMIN=generate-a-secure-token
AUTH_TOKEN_AGENT=generate-a-secure-token
AUTH_TOKEN_DISCORD=generate-a-secure-token
AUTH_TOKEN_READONLY=generate-a-secure-token
AUTH_TOKEN_N8N=generate-a-secure-token

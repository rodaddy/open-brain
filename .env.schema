# Open Brain Environment Schema
# Usage: varlock load (validates and populates .env from this schema)

# Database (shared PostgreSQL instance)
DB_HOST=10.71.20.49
DB_PORT=5432
DB_NAME=open_brain
DB_USER=open_brain
DB_PASSWORD=@secret(exec(./fetch-secrets.sh DB_PASSWORD))

# LiteLLM Proxy
LITELLM_URL=http://10.71.20.53:4000
LITELLM_API_KEY=@secret(exec(./fetch-secrets.sh LITELLM_API_KEY))

# Server
PORT=3100

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=@optional

# Auth tokens (one per consumer)
AUTH_TOKEN_ADMIN=@secret(exec(./fetch-secrets.sh AUTH_TOKEN_ADMIN))
AUTH_TOKEN_AGENT=@secret(exec(./fetch-secrets.sh AUTH_TOKEN_AGENT))
AUTH_TOKEN_DISCORD=@secret(exec(./fetch-secrets.sh AUTH_TOKEN_DISCORD))
AUTH_TOKEN_N8N=@secret(exec(./fetch-secrets.sh AUTH_TOKEN_N8N))
AUTH_TOKEN_READONLY=@secret(exec(./fetch-secrets.sh AUTH_TOKEN_READONLY))

{
  "id": "spool-redact-before-persist",
  "description": "Secret-like material is redacted before a durable spool record reaches disk or replay.",
  "capability": "redact-before-persist",
  "runtime": "python",
  "consumers": ["python"],
  "request": {
    "operation": "log_thought",
    "payload": {
      "content": "password: leakmark-contract-fixture-secret-123456"
    },
    "key": "redact-fixture-key"
  },
  "expectation": {
    "persisted_payload": {"content": "[REDACTED]"},
    "forbidden_substrings": ["leakmark-contract-fixture-secret-123456"],
    "file_mode": "0600"
  }
}

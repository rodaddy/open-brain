#!/usr/bin/env zsh
set -eu

# Open Brain pre-push gate.
# Preserve the existing full validation and add path-sensitive Python/parity gates.

echo "pre-push: running Open Brain validation..."

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

ZERO_SHA=0000000000000000000000000000000000000000
SAW_RANGE=no
CHANGED_PYTHON=no
CHANGED_PARITY=no

while read -r _local_ref local_sha _remote_ref remote_sha; do
  SAW_RANGE=yes
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi
  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    if git rev-parse --verify origin/main >/dev/null 2>&1; then
      base_sha="$(git merge-base "$local_sha" origin/main)"
    elif git rev-parse --verify main >/dev/null 2>&1; then
      base_sha="$(git merge-base "$local_sha" main)"
    else
      base_sha="$(git hash-object -t tree /dev/null)"
    fi
  else
    base_sha="$remote_sha"
  fi

  if [ -n "$(git diff --name-only "$base_sha" "$local_sha" -- python/openbrain-memory)" ]; then
    CHANGED_PYTHON=yes
  fi
  if [ -n "$(git diff --name-only "$base_sha" "$local_sha" -- \
    python/openbrain-memory contracts clients/ts \
    src/contract.ts src/contract-schemas.ts)" ]; then
    CHANGED_PARITY=yes
  fi
done

# A direct/manual invocation has no pre-push stdin. Compare the current branch
# to main so local hook testing retains useful behavior.
if [ "$SAW_RANGE" = no ]; then
  if git rev-parse --verify origin/main >/dev/null 2>&1; then
    BASE="$(git merge-base HEAD origin/main)"
  elif git rev-parse --verify main >/dev/null 2>&1; then
    BASE="$(git merge-base HEAD main)"
  else
    BASE="HEAD^"
  fi
  if [ -n "$(git diff --name-only "$BASE" HEAD -- python/openbrain-memory)" ]; then
    CHANGED_PYTHON=yes
  fi
  if [ -n "$(git diff --name-only "$BASE" HEAD -- \
    python/openbrain-memory contracts clients/ts \
    src/contract.ts src/contract-schemas.ts)" ]; then
    CHANGED_PARITY=yes
  fi
fi

echo "  bun run typecheck ..."
bun run typecheck
echo "  ✓ TypeScript passed"

echo "  bun test ..."
bun test
echo "  ✓ Bun tests passed"

if [ "$CHANGED_PYTHON" = yes ]; then
  echo "  Python package changed; running Python validation ..."
  (
    cd python/openbrain-memory
    echo "    uv run mypy src/openbrain_memory ..."
    uv run mypy src/openbrain_memory
    echo "    ✓ mypy passed"

    echo "    uv run ruff check src tests ..."
    uv run ruff check src tests
    echo "    ✓ ruff passed"

    echo "    uv run pytest -q ..."
    uv run pytest -q
    echo "    ✓ pytest passed"
  )
else
  echo "  Python package unchanged; skipping Python package gate"
fi

if [ "$CHANGED_PARITY" = yes ]; then
  echo "  Client/contract paths changed; running contract parity subset ..."
  bun contracts/check-parity.ts
  (
    cd python/openbrain-memory
    uv run pytest -q tests/test_contract_fixtures.py
  )
  echo "  ✓ Contract parity passed"
else
  echo "  Client/contract paths unchanged; skipping contract parity subset"
fi

echo "pre-push: all checks passed ✓"
